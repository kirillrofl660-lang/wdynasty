# === Обязательные ===

# Секретный ключ Payload CMS (сгенерируй случайную строку 32+ символов)
# Генерация: openssl rand -base64 32
PAYLOAD_SECRET=your-very-long-secret-key-here

# URL сервера (используется в Payload и Next.js)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# === База данных ===

# SQLite (dev / простой деплой)
TURSO_DATABASE_URL=file:./data/local.db

# Или Turso (облачный SQLite, для продакшена)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# === GitHub Container Registry ===

# Имя образа для docker-compose.prod.yml
# Формат: ghcr.io/GITHUB_USERNAME/REPO_NAME:TAG
GHCR_IMAGE=ghcr.io/yourusername/wdynasty:latest

# Порт, на котором будет доступен сайт на сервере
PORT=3000
